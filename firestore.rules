rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /products/{productId} {
      // Public can read products catalog and save/seed items
      allow read, write: if true;
    }

    match /requests/{requestId} {
      // Anyone can submit and view quote inquiry requests
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}

